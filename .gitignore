__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store

# Local secrets and shell environments
.env
.env.*

# Runtime logs and failed API attempts; successful artifacts are kept.
*.errors

# LaTeX build intermediates for generated reports.
reports/*.aux
reports/*.log
reports/*.out

# Download caches; canonical dataset files are committed separately.
datasets/**/.cache/

# Large local benchmark downloads kept outside the repository snapshot.
datasets/TraceElephant/
datasets/TraceElephant_hf/

# Nested repositories downloaded as source dependencies.
external/*/.git/
